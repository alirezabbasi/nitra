# Core Database
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
TIMESCALEDB_DATA_PATH=./.runtime-data/timescaledb
REDIS_DATA_PATH=./.runtime-data/redis
KAFKA_DATA_PATH=./.runtime-data/kafka
MINIO_DATA_PATH=./.runtime-data/minio

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_NODE_ID=1
KAFKA_CLUSTER_ID=mkV1OEVBNTcwNTJENDM2Qg
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:29092

# Object Storage (MinIO)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# MLflow
MLFLOW_BACKEND_STORE_URI=postgresql://trading:trading@timescaledb:5432/trading
MLFLOW_ARTIFACT_ROOT=s3://mlflow/

# Charting
CHARTING_PORT=8110
CHARTING_TIMEFRAME=1m
CHARTING_DEFAULT_LIMIT=300
CHARTING_REFRESH_SECS=5

# Ingestion Shared
INGESTION_HEALTH_TOPIC=connector.health
INGESTION_SYMBOL_SOURCE=database
INGESTION_DB_REFRESH_SECS=30
FX_WEEKEND_START_ISO_DOW=6
FX_WEEKEND_START_HOUR_UTC=0
FX_WEEKEND_END_ISO_DOW=1
FX_WEEKEND_END_HOUR_UTC=6

# OANDA Ingestion Profile
OANDA_RAW_TOPIC=raw.market.oanda
OANDA_DEFAULT_INSTRUMENT=EURUSD
OANDA_ENABLED_INSTRUMENTS=EURUSD,GBPUSD,USDJPY
OANDA_POLL_INTERVAL_SECS=1.0
OANDA_STREAM_URL=https://stream-fxpractice.oanda.com/v3/accounts/<account_id>/pricing/stream
OANDA_REST_URL=https://api-fxpractice.oanda.com
OANDA_ACCOUNT_ID=<oanda-account-id>
OANDA_API_TOKEN=replace-with-oanda-token
OANDA_INSTRUMENT_MAP=

# CAPITAL Ingestion Profile
CAPITAL_RAW_TOPIC=raw.market.capital
CAPITAL_DEFAULT_INSTRUMENT=EURUSD
CAPITAL_ENABLED_INSTRUMENTS=EURUSD,GBPUSD
CAPITAL_POLL_INTERVAL_SECS=1.0
CAPITAL_API_URL=https://api-capital.backend-capital.com
CAPITAL_API_KEY=replace-with-capital-api-key
CAPITAL_IDENTIFIER=replace-with-capital-identifier
CAPITAL_API_PASSWORD=replace-with-capital-api-password
CAPITAL_EPIC_ALLOWLIST=EURUSD,GBPUSD
CAPITAL_EPIC_MAP=

# COINBASE Ingestion Profile
COINBASE_RAW_TOPIC=raw.market.coinbase
COINBASE_DEFAULT_INSTRUMENT=BTCUSD
COINBASE_ENABLED_INSTRUMENTS=BTCUSD,ETHUSD,SOLUSD,ADAUSD,XRPUSD
COINBASE_POLL_INTERVAL_SECS=1.0
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
COINBASE_REST_URL=https://api.exchange.coinbase.com
COINBASE_PUBLIC_REST_URL=https://api.coinbase.com
COINBASE_PRODUCT_ALLOWLIST=BTCUSD,ETHUSD,SOLUSD,ADAUSD,XRPUSD
COINBASE_CHANNELS=ticker

# Backfill/Replay Recovery Controls
BACKFILL_RECOVERY_ENABLED=true
BACKFILL_RECOVERY_INTERVAL_SECS=30
BACKFILL_RECOVERY_BATCH_SIZE=1500
BACKFILL_STALE_RUNNING_SECS=600
BACKFILL_QUEUED_STALE_SECS=900
BACKFILL_REENQUEUE_COOLDOWN_SECS=90
BACKFILL_FAILED_RETRY_ENABLED=true
BACKFILL_FAILED_RETRY_AFTER_SECS=21600
BACKFILL_FAILED_RETRY_MAX_ATTEMPTS=6
BACKFILL_FAILED_RETRY_BATCH_SIZE=300
BACKFILL_REPLAY_QUEUE_BACKPRESSURE_ENABLED=true
BACKFILL_REPLAY_QUEUE_HIGH_WATERMARK=120000
BACKFILL_REPLAY_QUEUE_LOW_WATERMARK=90000
BACKFILL_REPLAY_QUEUE_MIN_BATCH=100
REPLAY_WORKER_COUNT=8
REPLAY_OANDA_INSTRUMENT_MAP=
REPLAY_COINBASE_USER_AGENT=nitra-replay-controller/1.0
